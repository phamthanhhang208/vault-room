# ─────────────────────────────────────────────────────────────────────────────
# VaultRoom — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Network Mode ──────────────────────────────────────────────────────────────
# 'testnet' → Cardano Preprod + Ethereum Sepolia (for demo, no real funds)
# 'mainnet' → Cardano Mainnet + Ethereum Mainnet (production)
NETWORK_MODE=testnet

# ── Notion MCP (OAuth) ────────────────────────────────────────────────────────
# Remote Notion MCP server URL (default is fine)
NOTION_MCP_URL=https://mcp.notion.com/mcp

# OAuth access token for the Notion MCP server
# To get this: authorize VaultRoom at https://notion.so/my-integrations (OAuth)
# Then copy the access token here. Tokens expire after 1 hour; use refresh token to renew.
NOTION_ACCESS_TOKEN=

# OAuth refresh token (optional — used to renew expired access tokens)
NOTION_REFRESH_TOKEN=

# Create a blank Notion page, then copy its ID from the URL
# URL format: https://notion.so/workspace/Page-Name-<PAGE_ID>
NOTION_PARENT_PAGE_ID=

# ── Blockchain — Cardano ──────────────────────────────────────────────────────
# Get a free API key at https://blockfrost.io
# For testnet: create a "Cardano Preprod" project → key starts with "preprod..."
# For mainnet: create a "Cardano Mainnet" project → key starts with "mainnet..."
BLOCKFROST_API_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cardano network (auto-derived from NETWORK_MODE: preprod for testnet, mainnet for production)
# Override here if needed: mainnet | preprod | preview | sanchonet
BLOCKFROST_NETWORK=preprod

# ── Blockchain — Ethereum ─────────────────────────────────────────────────────
# Leave empty to auto-derive from NETWORK_MODE:
#   testnet → https://rpc.sepolia.org
#   mainnet → https://eth.llamarpc.com
# Or set explicitly for Alchemy/Infura for higher rate limits
ETH_RPC_URL=

# Optional: Etherscan API key for tx history (get at https://etherscan.io/apis)
# For Sepolia testnet, use the same key — it covers both networks
ETHERSCAN_API_KEY=

# ── AI — Google Gemini ────────────────────────────────────────────────────────
# Get a free API key at https://aistudio.google.com
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Notion DB IDs — auto-populated by `pnpm run setup`
# You can also fill these in manually from your Notion DB URLs
# ─────────────────────────────────────────────────────────────────────────────
NOTION_CONFIG_DB_ID=
NOTION_WATCHLIST_DB_ID=
NOTION_RISK_DASHBOARD_DB_ID=
NOTION_POSITIONS_DB_ID=
NOTION_ALERT_LOG_DB_ID=
NOTION_DIGESTS_PAGE_ID=
